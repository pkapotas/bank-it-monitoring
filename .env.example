# ============================================================
# Bank IT Operations Monitoring System — Environment Variables
# Copy this file to .env and fill in your real credentials
# NEVER commit .env to version control
# ============================================================

# Anthropic Claude API (required)
ANTHROPIC_API_KEY=sk-ant-api03-...

# ----------------------------------------------------------
# Dynatrace
# ----------------------------------------------------------
# Your Dynatrace SaaS tenant URL
DYNATRACE_BASE_URL=https://YOUR_TENANT_ID.live.dynatrace.com
# API Token with scopes: problems.read, metrics.read, entities.read,
# synthetic.read, slo.read, settings.read
DYNATRACE_API_TOKEN=dt0c01.XXXXXXXXXXXXXXXXXXXX.YYYYYYYYYYYYYYYYYYYY
DYNATRACE_ENV_ID=YOUR_TENANT_ID

# ----------------------------------------------------------
# Azure Monitor
# ----------------------------------------------------------
# Service Principal with Reader + Log Analytics Reader roles
AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_SECRET=your-client-secret-here
AZURE_SUBSCRIPTION_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_RESOURCE_GROUP=bank-prod-rg
AZURE_LOG_WORKSPACE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ----------------------------------------------------------
# Kibana / Elasticsearch
# ----------------------------------------------------------
KIBANA_BASE_URL=https://kibana.your-bank.internal:5601
KIBANA_USERNAME=monitoring-readonly
KIBANA_PASSWORD=your-kibana-password
# Or use API key instead of username/password:
KIBANA_API_KEY=your-kibana-api-key-base64encoded==
ELASTICSEARCH_URL=https://elasticsearch.your-bank.internal:9200

# ----------------------------------------------------------
# Monitoring Thresholds
# ----------------------------------------------------------
MONITORING_LOOKBACK_MINUTES=60
CRITICAL_ERROR_RATE=5.0
WARNING_ERROR_RATE=2.0
CRITICAL_RESPONSE_MS=3000
WARNING_RESPONSE_MS=1000
